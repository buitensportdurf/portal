<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title is defined %}{{ title }}{% else %}Durf ledenportaal{% endif %}</title>
    <link rel="shortcut icon" type="image/jpg" href="/favicon.svg">
    <script src="https://kit.fontawesome.com/3471b6556e.js" crossorigin="anonymous"></script>

    {% block css %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="{{ asset('css/durf.css') }}">
    {% endblock %}
</head>
<body class="bg-light">
{{ include('base/navbar.html.twig') }}

<div class="container">
    <div class="row">
        <div class="col-sm mx-auto">
            {% block flashes %}
                {% for msg in app.session.flashBag.get('error') %}
                    <div class="alert alert-danger my-2" role="alert">
                        {{ msg|raw }}
                    </div>
                {% endfor %}
                {% for msg in app.session.flashBag.get('success') %}
                    <div class="alert alert-success my-2">
                        {{ msg|raw }}
                    </div>
                {% endfor %}
            {% endblock %}
        </div>
    </div>
</div>

{% block content %}
{% endblock %}

<div class="container-fluid bg-light">
    <div class="container">
        <div class="row my-3">
            <div class="col-sm mx-auto">
                {{ include('base/footer.html.twig') }}
            </div>
        </div>
    </div>
</div>

{% block js %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
</body>
</html>
