<nav class="navbar navbar-expand-md navbar-light shadow px-5">
    <div style="width: 160px; height: 80px" class="d-flex align-items-center">
        {% if app.request.attributes.get('_route') == 'event_event_index' %}
            <a class="navbar-brand m-0" href="{{ main_website }}">
                <img src="{{ asset('/logo.svg') }}" alt="Logo" height="80">
            </a>
        {% else %}
            <a class="btn btn-primary" href="{{ path('event_event_index') }}">Back to events</a>
        {% endif %}
    </div>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar"
            aria-controls="navbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse justify-content-end" id="navbar">
        <ul class="navbar-nav mb-2 mb-md-0 align-items-center">
            {% set route = app.request.attributes.get('_route') %}
            <li class="nav-item">
                <a class="nav-link {% if route == 'event_event_index' %}active{% endif %}"
                   href="{{ path('event_event_index') }}">Events</a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if route == 'event_event_past' %}active{% endif %}"
                   href="{{ path('event_event_past') }}">Past events</a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if route starts with 'event_calendar' %}active{% endif %}"
                   href="{{ path('event_calendar_index') }}">Calendars</a>
            </li>
            {% if is_granted('ROLE_EVENT_RECURRING') %}
                <li class="nav-item">
                    <a class="nav-link {% if route starts with 'event_recurring' %}active{% endif %}"
                       href="{{ path('event_recurring_event_index') }}">Recurring</a>
                </li>
            {% endif %}
            {% if is_granted("ROLE_ADMIN_USER") %}
                <li class="nav-item">
                    <a class="nav-link {% if route starts with 'admin2_user' %}active{% endif %}"
                       href="{{ path('admin2_user_index') }}">User activation</a>
                </li>
            {% endif %}
            {% if is_granted("ROLE_ADMIN") %}
                <li class="nav-item">
                    <a class="nav-link {% if route == 'admin' %}active{% endif %}"
                       href="{{ path('admin') }}">Admin</a>
                </li>
            {% endif %}
            {% if is_granted('IS_IMPERSONATOR') %}
                <li class="nav-item">
                    <a class="badge bg-warning text-decoration-none" href="{{ impersonation_exit_path(
                        path(route, app.request.attributes.get('_route_params'))
                    ) }}">Exit impersonation</a>
                </li>
            {% endif %}
            {% if is_granted("IS_AUTHENTICATED_REMEMBERED") %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                       aria-expanded="false">
                        <span class="position-relative d-inline-block me-1">
                            {{ app.user.name }}
                            <span class="position-absolute top-0 start-100 translate-middle d-flex gap-1 navbar-corner-badges">
                                {% if app.user.guest %}
                                    <span class="badge rounded-pill bg-secondary navbar-corner-badge">Guest</span>
                                {% elseif is_granted("ROLE_ADMIN") %}
                                    <span class="badge rounded-pill bg-primary navbar-corner-badge">Admin</span>
                                {% endif %}
                                {% if app.environment == 'dev' %}
                                    <span class="badge rounded-pill bg-danger navbar-corner-badge">dev</span>
                                {% endif %}
                            </span>
                        </span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        {% if not app.user.guest %}
                            <li><a class="dropdown-item" href="{{ path('user_profile') }}">Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                        {% endif %}
                        <li><a class="dropdown-item" href="{{ path('_logout_main') }}">Logout</a></li>
                    </ul>
                </li>
            {% else %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('login') }}">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('register') }}">Register</a>
                </li>
            {% endif %}
        </ul>
    </div>
</nav>
