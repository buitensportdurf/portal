{% extends 'base/single.column.html.twig' %}

{% set title %}Recurring event {{ recurringEvent }}{% endset %}

{% block body %}
    <div class="btn btn-group">
        <a class="btn btn-primary" href="{{ path('event_recurring_event_index') }}">Back</a>
        {% if is_granted('ROLE_EVENT_RECURRING') %}
            <a class="btn btn-warning"
               href="{{ path('event_recurring_event_edit', {'id': recurringEvent.id}) }}">Edit</a>
            <a class="btn btn-success"
               href="{{ path('event_recurring_event_create_events', {'id': recurringEvent.id}) }}">Create events</a>
            <a class="btn btn-danger" data-bs-toggle="modal"
               data-bs-target="#confirmDeleteEvents">Delete events</a>
            {{ include('components/_confirm_modal.html.twig', {
                id: 'confirmDeleteEvents',
                title: 'Delete future events',
                message: 'You are about to delete all future events for "' ~ recurringEvent ~ '", this will delete all subscriptions as well. Are you sure?',
                action_url: path('event_recurring_event_delete_events', {id: recurringEvent.id}),
                action_label: 'Delete events',
            }) }}
        {% endif %}
    </div>
    <h5>Upcoming events</h5>
    <div class="row row-cols-1 row-cols-md-3 g-3">
        {% for event in recurringEvent.futureEvents %}
            <div class="col">
                {{ include('event/event/card.html.twig', {event: event}) }}
            </div>
        {% endfor %}
    </div>
    <h5>Past events</h5>
    <div class="row row-cols-1 row-cols-md-3 g-3">
        {% for event in recurringEvent.pastEvents %}
            <div class="col">
                {{ include('event/event/card.html.twig', {event: event}) }}
            </div>
        {% endfor %}
    </div>
{% endblock %}

