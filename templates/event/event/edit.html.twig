{% extends 'base/single.column.html.twig' %}

{% set title %}Edit Event {{ event }}{% endset %}

{% block body %}
    <a class="btn btn-primary" href="{{ path('event_event_index') }}">Back to list</a>
    <a class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteEvent">Delete</a>
    {{ include('components/_confirm_modal.html.twig', {
        id: 'confirmDeleteEvent',
        title: 'Delete event',
        message: 'Are you sure you want to delete event "' ~ event ~ '"?',
        action_url: path('event_event_delete', {id: event.id}),
        action_label: 'Delete',
    }) }}

    {{ form(form) }}
{% endblock %}
