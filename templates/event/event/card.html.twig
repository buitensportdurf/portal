{# @var event App\Entity\Event\Event #}
{% set subscription = event.subscription(app.user) %}
<div class="card h-100{% if not event.published %} opacity-50{% endif %}">
    {% if event.image %}
        <img class="card-img-top" src="{{ vich_uploader_asset(event.image) }}" alt="{{ event.name }} image">
    {% endif %}

    <div class="card-body">
        <h4 class="card-title">
            <a class="text-decoration-none text-dark stretched-link" href="{{ path('event_event_show', {'id': event.id}) }}">{{ event }}</a>
        </h4>
        <p class="card-text text-muted small mb-2">
            {% if not event.published %}
                <span class="badge bg-secondary">Draft</span>
            {% endif %}
            {% for tag in event.tags %}
                <span class="badge bg-primary">{{ tag }}</span>
            {% endfor %}
        </p>
        <ul class="list-unstyled small mb-2">
            <li><i class="fas fa-calendar fa-fw"></i> {{ event.startDate ? event.startDate|fdate_time : '' }}</li>
            <li><i class="fas fa-clock fa-fw"></i> {{ event.duration|time_duration }}</li>
            <li><i class="fas fa-map-marker-alt fa-fw"></i> {{ event.location }}</li>
            {% if event.amountOfSubscriptions > 0 %}
                <li><i class="fas fa-users fa-fw"></i> {{ event.amountOfSubscriptions }} subscribed</li>
            {% endif %}
        </ul>
        <p class="card-text small">{{ event.description|truncate(100)|markdown_to_html }}</p>
    </div>

    {% if subscription %}
        <div class="card-footer bg-success-subtle">
            <div class="d-flex justify-content-between align-items-center">
                <small>You are subscribed</small>
                <span class="badge bg-success rounded-pill">{{ subscription.amount }}</span>
            </div>
        </div>
    {% endif %}

    <div class="card-footer bg-transparent position-relative" style="z-index: 2">
        {% if subscription and is_granted('unsubscribe', event) %}
            <a class="btn btn-sm btn-outline-danger w-100" data-bs-toggle="modal"
               data-bs-target="#confirmUnsubscribe{{ event.id }}">Unsubscribe</a>
            {{ include('components/_confirm_modal.html.twig', {
                id: 'confirmUnsubscribe' ~ event.id,
                title: 'Unsubscribe from ' ~ event,
                message: 'Are you sure you want to unsubscribe from "' ~ event ~ '"?',
                action_url: path('event_subscription_unsubscribe', {id: subscription.id}),
                action_label: 'Unsubscribe',
                action_class: 'btn-warning',
            }) }}
        {% elseif is_granted('subscribe', event) or not is_granted('IS_AUTHENTICATED_REMEMBERED') %}
            <a class="btn btn-sm btn-success w-100"
               href="{{ path('event_subscription_subscribe', {'id': event.id}) }}">Subscribe</a>
        {% elseif event.subscriptionOpenDate and not event.isPastSubscriptionOpenDate %}
            <small class="text-muted">Subscriptions open {{ event.subscriptionOpenDate|fdate_time }}</small>
        {% endif %}
    </div>
</div>
