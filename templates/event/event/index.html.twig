{% extends 'base/single.column.html.twig' %}

{% set title %}Upcoming events{% endset %}

{% block actions %}
    {% if is_granted('ROLE_EVENT_EDIT') %}
        <a class="btn btn-sm btn-outline-success" href="{{ path('event_event_new') }}">Create new</a>
    {% endif %}
{% endblock %}

{% block body %}
    <div class="mb-3">
        <small class="text-muted d-block mb-1">Filter by tag</small>
        {% for tagOption in tags %}
            {% if tagOption == tag %}
                <a class="btn btn-sm btn-success" href="{{ path('event_event_index') }}"
                   title="Showing only '{{ tagOption }}' events — click to clear filter">{{ tagOption }}</a>
            {% else %}
                <a class="btn btn-sm btn-{% if tagOption.defaultHide %}outline-danger{% else %}outline-primary{% endif %}"
                   href="{{ path('event_event_index', {tag: tagOption.name}) }}"
                   title="{% if tagOption.defaultHide %}Hidden by default — click to show only '{{ tagOption }}' events{% else %}Click to show only '{{ tagOption }}' events{% endif %}">{{ tagOption }}</a>
            {% endif %}
        {% endfor %}
    </div>

    {% if events is empty %}
        <div class="text-center py-5 text-muted">
            <p class="fs-5">No upcoming events</p>
            {% if not app.user %}
                <p><a href="{{ path('register') }}">Register</a> or <a href="{{ path('login') }}">login</a> to subscribe to events.</p>
            {% endif %}
        </div>
    {% else %}
        {% if not app.user %}
            <p class="text-muted small mb-3">
                <a href="{{ path('register') }}">Register</a> or <a href="{{ path('login') }}">login</a> to subscribe to events.
            </p>
        {% endif %}
        <div class="row row-cols-1 row-cols-md-3 g-3">
            {% for event in events %}
                <div class="col">
                    {{ include('event/event/card.html.twig', {event: event}) }}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
