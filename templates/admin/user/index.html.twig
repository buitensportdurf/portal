{% extends 'base/single.column.html.twig' %}

{% set title %}All users{% endset %}

{% block body %}
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Enable</th>
        </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.name }}</td>
                <td>{{ user.email }}</td>
                <td>
                    <a class="btn btn-sm btn-success" data-bs-toggle="modal"
                       data-bs-target="#confirmEnable{{ user.id }}">Enable</a>
                    {{ include('components/_confirm_modal.html.twig', {
                        id: 'confirmEnable' ~ user.id,
                        title: 'Enable ' ~ user.name,
                        message: 'Do you really want to enable "' ~ user.name ~ '" with email "' ~ user.email ~ '"?',
                        action_url: path('admin2_user_enable', {id: user.id}),
                        action_label: 'Enable',
                        action_class: 'btn-success',
                    }) }}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}